# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=<your-project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey_<your-anon-key-here>
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_<your-publishable-default-key-here>
SUPABASE_SECRET_KEY=sb_secret_<your-secret-key-here>

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
# run `npx auth secret` to generate a secure secret
# NextAuth v5 uses AUTH_SECRET, but NEXTAUTH_SECRET is also supported for backwards compatibility
AUTH_SECRET="<your-auth-secret-here>"
NEXTAUTH_SECRET="<your-nextauth-secret-here>"

# App Settings
NEXT_PUBLIC_APP_NAME="Hope's Corner"

# GitHub Feedback Issue Creation
# Token needs permission to create issues in the feedback repository and assign Copilot.
GITHUB_FEEDBACK_TOKEN=github_pat_<your-token-here>
# Optional: defaults to karangattu/hopes-corner-app when omitted.
GITHUB_FEEDBACK_OWNER=karangattu
GITHUB_FEEDBACK_REPO=hopes-corner-app
# Optional: override if your organization uses a different Copilot coding agent assignee.
GITHUB_FEEDBACK_ASSIGNEE=copilot


# ------------------------------------------------------------------------------
# OPTIONAL - Development Settings
# ------------------------------------------------------------------------------

# Set to 'development' or 'production'
# NODE_ENV=development

# Enable verbose logging (optional)
# DEBUG=true
